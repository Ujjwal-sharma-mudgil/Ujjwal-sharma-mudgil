import random
import string

def generate_password():
    print("🔐 Secure Password Generator 🔐")
    
    try:
        length = int(input("Enter the desired length of the password (min 6): "))
        if length < 6:
            print("⚠️ Length too short! Setting it to minimum length of 6.")
            length = 6
            
        # Combine all possible characters: lowercase, uppercase, digits, and punctuation
        all_characters = string.ascii_letters + string.digits + string.punctuation
        
        # Pick random characters from the pool and combine them
        password = "".join(random.choice(all_characters) for i in range(length))
        
        print(f"🚀 Your secure password is: {password}")
        
    except ValueError:
        print("❌ Please enter a valid number for the length.")

if __name__ == "__main__":
    generate_password()
